{
  "name": "maidspace",
  "version": "0.2.0",
  "private": true,
  "description": "MaidSpace: utilitario local para manter espaco livre com inventario rapido e limpeza assistida.",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-maidspace.ps1",
    "core:check": "cmd /c scripts\\with-vsdev.cmd cargo check --manifest-path src-core/add-core/Cargo.toml",
    "core:run": "cmd /c scripts\\with-vsdev.cmd cargo run --manifest-path src-core/add-core/Cargo.toml --",
    "desktop": "npm run maidspace:dev",
    "fallback": "node src/desktop/launcher.js",
    "maidspace:dev": "cmd /c scripts\\with-vsdev.cmd npx @tauri-apps/cli dev",
    "maidspace:build": "cmd /c scripts\\with-vsdev.cmd npx @tauri-apps/cli build",
    "maidspace:build:local": "powershell -ExecutionPolicy Bypass -File scripts/maidspace-build.ps1",
    "start": "node server.js",
    "tauri:dev": "npm run maidspace:dev",
    "tauri:build": "npm run maidspace:build",
    "test": "node --test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
