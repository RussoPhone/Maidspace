{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MaidSpace",
  "version": "0.2.0",
  "identifier": "com.maidspace.desktop",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MaidSpace",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
